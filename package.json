{
  "name": "videl",
  "version": "0.4.0",
  "description": "A bad idea for a video player built with web components",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm-run-all -p build:*",
    "build:dist": "esbuild src/index.ts --bundle --loader:.css=text --platform=browser --target=es2020 --outfile=dist/index.js --format=esm",
    "build:dist-min": "esbuild src/index.ts --bundle --loader:.css=text --platform=browser --target=es2020 --outfile=dist/index.min.js --format=esm --minify --sourcemap",
    "build:demo": "esbuild demo/main.ts --bundle --loader:.css=text --platform=browser --target=es2022 --outfile=demo/dist/bundle.js --format=esm --sourcemap",
    "lint": "npm-run-all -p lint:*",
    "lint:fix": "eslint src",
    "lint:types": "tsc --noEmit",
    "test": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^20.0.0",
    "esbuild": "^0.19.0",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "npm-run-all": "^4.1.5",
    "playwright": "^1.40.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "keywords": [
    "video",
    "player",
    "media"
  ],
  "author": "Jon-Carlos Rivera <jon.carlos.rivera@gmail.com>",
  "license": "MIT",
  "allowScripts": {
    "esbuild@0.19.12": true
  },
  "dependencies": {
    "ergo-mse": "github:imbcmdth/ergo-mse#v1.1.0",
    "lit": "^3.3.3"
  }
}
