{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true,
    "types": ["node"],
    "paths": {
      "/dist/index.js": ["./src/index.ts"]
    }
  },
  "include": ["src/**/*", "demo/**/*", "test/**/*"]
}
